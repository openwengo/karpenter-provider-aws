# syntax=docker/dockerfile:1

ARG GO_VERSION=1.25
FROM golang:${GO_VERSION}-bookworm AS builder

WORKDIR /workspace
COPY . .

ARG LDFLAGS=""
RUN CGO_ENABLED=0 GOOS=linux GOARCH="${TARGETARCH:-amd64}" go build -trimpath -ldflags "${LDFLAGS}" -o /out/controller ./cmd/controller

FROM public.ecr.aws/eks-distro-build-tooling/eks-distro-minimal-base

USER 65532:65532
COPY --from=builder /out/controller /controller

ENTRYPOINT ["/controller"]
